{
  "name": "@fleetmgm/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export --platform android",
    "build:ios": "expo export --platform ios",
    "lint": "tsc --noEmit",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@fleetmgm/api": "*",
    "@fleetmgm/hooks": "*",
    "@fleetmgm/store": "*",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~54.0.36",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.25.0",
    "react": "19.2.7",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react-test-renderer": "^19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.16",
    "react-test-renderer": "19.2.7",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^lucide-react-native$": "<rootDir>/src/test/lucide-react-native.tsx"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native|@react-navigation|expo(nent)?|@expo(nent)?/.*|@fleetmgm/.*|@tanstack/.*))"
    ]
  }
}
